#!/usr/bin/env zsh
# theme-apply — regenerate every app's color fragment from the master palette.
# Idempotent. Run after editing configs/linux/theme/tokyonight.conf.
set -euo pipefail

SCRIPT_DIR="${0:A:h}"
MASTER="$SCRIPT_DIR/../configs/linux/theme/tokyonight.conf"
[[ -r "$MASTER" ]] || { print -u2 "theme-apply: master palette not found: $MASTER"; exit 1; }

# Load name=#hex pairs into an ordered assoc array.
typeset -A C
typeset -a ORDER
while IFS='=' read -r name hex; do
  [[ -z "$name" || "$name" == \#* ]] && continue
  C[$name]="$hex"        # e.g. #7aa2f7
  ORDER+=("$name")
done < "$MASTER"

gen_header="/* GENERATED by scripts/theme-apply from configs/linux/theme/tokyonight.conf — DO NOT EDIT */"
conf_header="# GENERATED by scripts/theme-apply from configs/linux/theme/tokyonight.conf — DO NOT EDIT"

# --- Hyprland: $name = 0xffRRGGBB ---
hypr_out="$HOME/.config/hypr/colors.conf"
mkdir -p "${hypr_out:h}"
{
  print -r -- "$conf_header"
  for n in $ORDER; do print -r -- "\$$n = 0xff${C[$n]#\#}"; done
} > "$hypr_out"

# --- hyprlock: $name = rgb(RRGGBB) ---
hyprlock_out="$HOME/.config/hypr/hyprlock-colors.conf"
mkdir -p "${hyprlock_out:h}"
{
  print -r -- "$conf_header"
  for n in $ORDER; do print -r -- "\$$n = rgb(${C[$n]#\#})"; done
} > "$hyprlock_out"

# --- GTK/CSS consumers: @define-color name #RRGGBB; ---
for css in "$HOME/.config/waybar/colors.css" "$HOME/.config/wofi/colors.css" "$HOME/.config/swaync/colors.css"; do
  mkdir -p "${css:h}"
  {
    print -r -- "$gen_header"
    for n in $ORDER; do print -r -- "@define-color $n ${C[$n]};"; done
  } > "$css"
done

print -r -- "theme-apply: wrote ${#ORDER} colors to hypr, hyprlock, waybar, wofi, swaync."
