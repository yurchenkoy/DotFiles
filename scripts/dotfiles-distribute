#!/usr/bin/env zsh
# dotfiles-distribute — copy configs FROM the dotfiles repo into live locations
# Usage: dotfiles-distribute [--dry-run] [--force]

set -euo pipefail

if [[ -n "${DOTFILES_DIR:-}" ]]; then
  REPO_DIR="$DOTFILES_DIR"
else
  REPO_DIR=$(find "$HOME/Documents" -maxdepth 3 -type d -name "DotFiles" 2>/dev/null | head -1)
  if [[ -z "$REPO_DIR" || ! -f "$REPO_DIR/setup.sh" ]]; then
    echo "  ✖  Could not find DotFiles repo under ~/Documents (depth ≤ 3)."
    echo "     Set \$DOTFILES_DIR to override."
    exit 1
  fi
fi
DRY_RUN=0
FORCE=0
for arg in "$@"; do
  [[ "$arg" == "--dry-run" ]] && DRY_RUN=1
  [[ "$arg" == "--force"   ]] && FORCE=1
done

# ── Config map ────────────────────────────────────────────────────────────────
# Add new entries as a matching quadruplet across all four arrays.
# type = file | dir

typeset -a LABELS=(
  "zsh"
  "ghostty"
  "nvim"
  "starship"
  "fsh"
  "alfred"
  "git"
  "karabiner"
  "aerospace"
)

typeset -a SOURCES=(
  "configs/zsh/.zshrc"
  "configs/ghostty/config"
  "configs/nvim"
  "configs/starship/starship.toml"
  "configs/fsh"
  "configs/alfred/Alfred.alfredpreferences"
  "configs/git/.gitconfig"
  "configs/karabiner/karabiner.json"
  "configs/aerospace/aerospace.toml"
)

typeset -a DESTINATIONS=(
  "$HOME/.zshrc"
  "$HOME/Library/Application Support/com.mitchellh.ghostty/config"
  "$HOME/.config/nvim"
  "$HOME/.config/starship.toml"
  "$HOME/.config/fsh"
  "$HOME/Library/Application Support/Alfred/Alfred.alfredpreferences"
  "$HOME/.gitconfig"
  "$HOME/.config/karabiner/karabiner.json"
  "$HOME/.config/aerospace/aerospace.toml"
)

typeset -a TYPES=(
  "file"
  "file"
  "dir"
  "file"
  "dir"
  "dir"
  "file"
  "file"
  "file"
)
# ──────────────────────────────────────────────────────────────────────────────

RED='\033[0;31m'; YELLOW='\033[1;33m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'; RESET='\033[0m'

echo "\n${CYAN}═══ dotfiles-distribute ═════════════════════════════${RESET}"
[[ $DRY_RUN -eq 1 ]] && echo "  ${YELLOW}DRY RUN — nothing will be written${RESET}\n"

# ── Selection menu ────────────────────────────────────────────────────────────
typeset -A SELECTED_SET=()
n=${#SOURCES[@]}

if [[ $FORCE -eq 1 ]]; then
  for i in {1..$n}; do SELECTED_SET[$i]=1; done
elif command -v fzf &>/dev/null; then
  selected_labels=$(printf '%s\n' "${LABELS[@]}" | fzf \
    --multi \
    --height=~60% \
    --layout=reverse \
    --border=rounded \
    --prompt="  distribute > " \
    --header="Tab·toggle  Ctrl-A·all  Enter·confirm  Esc·cancel" \
    --color="header:italic,border:cyan,prompt:cyan,marker:green" \
    --bind="ctrl-a:select-all,ctrl-d:deselect-all") || {
    echo "  Cancelled.\n"; exit 0
  }
  [[ -z "$selected_labels" ]] && echo "  Nothing selected.\n" && exit 0
  for i in {1..$n}; do
    if echo "$selected_labels" | grep -qxF "${LABELS[$i]}"; then SELECTED_SET[$i]=1; fi
  done
else
  echo "  ${CYAN}Select what to distribute (space-separated numbers, 'a' or enter for all):${RESET}\n"
  for i in {1..$n}; do
    printf "    %2d) %s\n" $i "${LABELS[$i]}"
  done
  echo ""
  echo -n "  > "
  read -r selection
  echo ""

  selection="${selection//,/ }"
  if [[ -z "$selection" || "$selection" == "a" ]]; then
    for i in {1..$n}; do SELECTED_SET[$i]=1; done
  else
    for token in ${=selection}; do
      if [[ "$token" =~ ^[0-9]+$ ]] && (( token >= 1 && token <= n )); then
        SELECTED_SET[$token]=1
      fi
    done
  fi
fi

# ── Diff preview ──────────────────────────────────────────────────────────────
echo "  ${CYAN}Previewing what would change on this machine:${RESET}\n"
diff_found=0

for i in {1..$n}; do
  [[ -z "${SELECTED_SET[$i]:-}" ]] && continue

  repo_src="$REPO_DIR/${SOURCES[$i]}"
  live_dst="${DESTINATIONS[$i]}"
  kind="${TYPES[$i]}"

  if [[ ! -e "$repo_src" ]]; then
    echo "  ${YELLOW}⚠${RESET}  Not in repo, skipping: $repo_src"
    continue
  fi

  if [[ ! -e "$live_dst" ]]; then
    echo "  ${GREEN}+${RESET}  New (does not exist yet): $live_dst"
    diff_found=1
    continue
  fi

  if [[ $kind == "file" ]]; then
    if ! diff -q "$repo_src" "$live_dst" &>/dev/null; then
      echo "  ${YELLOW}~${RESET}  Changed: $live_dst"
      diff --unified=2 --color=always "$live_dst" "$repo_src" | sed 's/^/      /' || true
      diff_found=1
    else
      echo "  ${GREEN}✔${RESET}  Up to date: $live_dst"
    fi
  else
    local delta
    delta=$(rsync -an --delete --out-format="%n" "$repo_src/" "$live_dst/" 2>/dev/null || true)
    if [[ -n "$delta" ]]; then
      echo "  ${YELLOW}~${RESET}  Dir has changes: $live_dst"
      echo "$delta" | sed 's/^/      /'
      diff_found=1
    else
      echo "  ${GREEN}✔${RESET}  Up to date: $live_dst"
    fi
  fi
done

echo ""

if [[ $diff_found -eq 0 ]]; then
  echo "  ${GREEN}Everything already up to date. Nothing to do.${RESET}\n"
  exit 0
fi

[[ $DRY_RUN -eq 1 ]] && exit 0

# ── Confirm unless --force ────────────────────────────────────────────────────
if [[ $FORCE -eq 0 ]]; then
  echo -n "  Apply these changes? (y/N) "
  read -r reply
  [[ "$reply" != "y" && "$reply" != "Y" ]] && echo "  Cancelled.\n" && exit 0
  echo ""
fi

# ── Apply ─────────────────────────────────────────────────────────────────────
changes=0
for i in {1..$n}; do
  [[ -z "${SELECTED_SET[$i]:-}" ]] && continue

  repo_src="$REPO_DIR/${SOURCES[$i]}"
  live_dst="${DESTINATIONS[$i]}"
  kind="${TYPES[$i]}"

  [[ ! -e "$repo_src" ]] && continue

  if [[ $kind == "dir" ]]; then
    mkdir -p "$live_dst"
    rsync -a --delete "$repo_src/" "$live_dst/"
    echo "  ${GREEN}✔${RESET}  Synced dir:  → $live_dst"
  else
    mkdir -p "$(dirname "$live_dst")"
    cp "$repo_src" "$live_dst"
    echo "  ${GREEN}✔${RESET}  Copied file: → $live_dst"
  fi
  changes=$((changes + 1))
done

echo ""
echo "  ${GREEN}Done.${RESET} $changes item(s) applied."
echo "  Restart your shell or: source ~/.zshrc"
echo ""
