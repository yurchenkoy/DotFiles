#!/usr/bin/env zsh
# dsync-down — copy configs FROM the dotfiles repo into live locations
# Usage: dsync-down [--dry-run] [--force]

set -euo pipefail

REPO_DIR="${DOTFILES_DIR:-$HOME/Documents/DotFiles}"
DRY_RUN=0
FORCE=0
for arg in "$@"; do
  [[ "$arg" == "--dry-run" ]] && DRY_RUN=1
  [[ "$arg" == "--force"   ]] && FORCE=1
done

# ── Config map ────────────────────────────────────────────────────────────────
# Format: "REPO_RELATIVE_PATH|LIVE_PATH|type"   type = file | dir
typeset -a CONFIG_MAP=(
  "configs/zsh/.zshrc|$HOME/.zshrc|file"
  "configs/ghostty/config|$HOME/Library/Application Support/com.mitchellh.ghostty/config|file"
  "configs/nvim|$HOME/.config/nvim|dir"
  "configs/starship/starship.toml|$HOME/.config/starship.toml|file"
  "configs/fsh|$HOME/.config/fsh|dir"
  "configs/alfred/Alfred.alfredpreferences|$HOME/Library/Application Support/Alfred/Alfred.alfredpreferences|dir"
  "configs/git/.gitconfig|$HOME/.gitconfig|file"
)
# ──────────────────────────────────────────────────────────────────────────────

RED='\033[0;31m'; YELLOW='\033[1;33m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'; RESET='\033[0m'

echo "\n${CYAN}═══ dsync-down ══════════════════════════════════════${RESET}"
[[ $DRY_RUN -eq 1 ]] && echo "  ${YELLOW}DRY RUN — nothing will be written${RESET}\n"

# ── Pull latest from remote (skip in dry-run) ─────────────────────────────────
if [[ $DRY_RUN -eq 0 ]]; then
  echo "  Pulling latest from remote..."
  git -C "$REPO_DIR" pull --ff-only || {
    echo "  ${RED}Git pull failed. Resolve conflicts in $REPO_DIR first.${RESET}"
    exit 1
  }
  echo ""
fi

# ── Diff preview ──────────────────────────────────────────────────────────────
echo "  ${CYAN}Previewing what would change on this machine:${RESET}\n"
diff_found=0

for entry in "${CONFIG_MAP[@]}"; do
  repo_rel="${entry%%|*}"
  rest="${entry#*|}"
  live_dst="${rest%%|*}"
  kind="${rest##*|}"
  repo_src="$REPO_DIR/$repo_rel"

  if [[ ! -e "$repo_src" ]]; then
    echo "  ${YELLOW}⚠${RESET}  Not in repo, skipping: $repo_src"
    continue
  fi

  if [[ ! -e "$live_dst" ]]; then
    echo "  ${GREEN}+${RESET}  New (does not exist yet): $live_dst"
    diff_found=1
    continue
  fi

  if [[ $kind == "file" ]]; then
    if ! diff -q "$repo_src" "$live_dst" &>/dev/null; then
      echo "  ${YELLOW}~${RESET}  Changed: $live_dst"
      diff --unified=2 --color=always "$live_dst" "$repo_src" | sed 's/^/      /' || true
      diff_found=1
    else
      echo "  ${GREEN}✔${RESET}  Up to date: $live_dst"
    fi
  else
    local delta
    delta=$(rsync -an --delete --out-format="%n" "$repo_src/" "$live_dst/" 2>/dev/null || true)
    if [[ -n "$delta" ]]; then
      echo "  ${YELLOW}~${RESET}  Dir has changes: $live_dst"
      echo "$delta" | sed 's/^/      /'
      diff_found=1
    else
      echo "  ${GREEN}✔${RESET}  Up to date: $live_dst"
    fi
  fi
done

echo ""

if [[ $diff_found -eq 0 ]]; then
  echo "  ${GREEN}Everything already up to date. Nothing to do.${RESET}\n"
  exit 0
fi

[[ $DRY_RUN -eq 1 ]] && exit 0

# ── Confirm unless --force ────────────────────────────────────────────────────
if [[ $FORCE -eq 0 ]]; then
  echo -n "  Apply these changes? (y/N) "
  read -r reply
  [[ "$reply" != "y" && "$reply" != "Y" ]] && echo "  Cancelled.\n" && exit 0
  echo ""
fi

# ── Apply ─────────────────────────────────────────────────────────────────────
changes=0
for entry in "${CONFIG_MAP[@]}"; do
  repo_rel="${entry%%|*}"
  rest="${entry#*|}"
  live_dst="${rest%%|*}"
  kind="${rest##*|}"
  repo_src="$REPO_DIR/$repo_rel"

  [[ ! -e "$repo_src" ]] && continue

  if [[ $kind == "dir" ]]; then
    mkdir -p "$live_dst"
    rsync -a --delete "$repo_src/" "$live_dst/"
    echo "  ${GREEN}✔${RESET}  Synced dir:  → $live_dst"
  else
    mkdir -p "$(dirname "$live_dst")"
    cp "$repo_src" "$live_dst"
    echo "  ${GREEN}✔${RESET}  Copied file: → $live_dst"
  fi
  ((changes++))
done

echo ""
echo "  ${GREEN}Done.${RESET} $changes item(s) applied."
echo "  Restart your shell or: source ~/.zshrc"
echo ""
